    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $json;\n\n// Find the LLM output in the current item\nlet aiText = $json.text || $json.output || ($json.message && $json.message.content) || \"\";\n\nlet aiData = {};\ntry {\n  if (aiText) {\n    let raw = aiText;\n    // Remove markdown code blocks\n    raw = raw.replace(/```json\\n?/gi, '').replace(/```\\n?/gi, '').trim();\n    // Find JSON object in the text\n    const jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) {\n      aiData = JSON.parse(jsonMatch[0]);\n    }\n  }\n} catch (e) {\n  aiData = {};\n}\n\n// Helper to get value from multiple possible key names\nfunction getVal(obj, ...keys) {\n  for (const key of keys) {\n    if (obj[key] !== undefined && obj[key] !== null && obj[key] !== '') {\n      return obj[key];\n    }\n  }\n  return '';\n}\n\n// Normalize recommendation to proper case\nlet recommendation = getVal(aiData, 'Recommendation', 'recommendation', 'RECOMMENDATION');\nif (typeof recommendation === 'string') {\n  recommendation = recommendation.trim();\n  if (recommendation.toLowerCase() === 'select') recommendation = 'Select';\n  if (recommendation.toLowerCase() === 'reject') recommendation = 'Reject';\n}\n\nreturn {\n    Email: original.Email || '',\n    Name: original.Name || '',\n    Timestamp: original.Timestamp || '',\n    ATS_Score: getVal(aiData, 'ATS_Score', 'ats_score', 'ATSScore', 'ats'),\n    Skills_Match: getVal(aiData, 'Skills_Match', 'skills_match', 'SkillsMatch', 'skills'),\n    PAR_Rating: getVal(aiData, 'PAR_Rating', 'par_rating', 'PARRating', 'par'),\n    Experience_Clarity: getVal(aiData, 'Experience_Clarity', 'experience_clarity', 'ExperienceClarity', 'experience'),\n    Overall_Grade: getVal(aiData, 'Overall_Grade', 'overall_grade', 'OverallGrade', 'grade'),\n    Recommendation: recommendation,\n    Top_Strength: getVal(aiData, 'Top_Strength', 'top_strength', 'TopStrength', 'strength'),\n    Main_Gap: getVal(aiData, 'Main_Gap', 'main_gap', 'MainGap', 'gap'),\n    Processed: 'YES'\n};"
      },
